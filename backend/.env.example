# Backend environment variables
DATABASE_URL=postgresql://postgres:password@localhost:5432/signalflow

# Get from https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key

# Get from https://peopledatalabs.com — used for BOTH company search AND contact search
PEOPLE_DATA_LABS_API_KEY=your_pdl_api_key

# Get from https://www.firecrawl.dev/
FIRECRAWL_API_KEY=your_firecrawl_api_key

# Get from https://tavily.com/
TAVILY_API_KEY=your_tavily_api_key
